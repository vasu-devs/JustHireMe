{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JustHireMe",
  "version": "0.1.30",
  "identifier": "com.vasudev-siddh.justhireme",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "JustHireMe",
        "width": 1440,
        "height": 900,
        "minWidth": 960,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost data: blob:; font-src 'self'; connect-src http://127.0.0.1:* ws://127.0.0.1:*; frame-src 'self' blob: data:; object-src 'self' blob: data:"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "externalBin": [
      "resources/backend/jhm-sidecar-next"
    ],
    "resources": {
      "resources/sidecar-internal": "_internal"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "installerHooks": "windows/nsis-hooks.nsh"
      },
      "wix": {
        "language": "en-US"
      }
    },
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEEwRTc5MkU0MEM3MDU4OTYKUldTV1dIQU01Skxub0I3NDZySUdrd1NBVkh1Q0srOVl2LzZwdUQzMzY0TmxEN2w0akNRTEY3ei8K",
      "endpoints": [
        "https://github.com/vasu-devs/JustHireMe/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
